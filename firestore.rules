rules_version = '2';

// GG Toolbox QR tracking stores its data in the "qrLinks" collection. Every
// read and write goes through the Cloud Function (Admin SDK), which bypasses
// these rules. Direct client access is denied outright: the stats token is
// the only key to a code, and clients must never be able to enumerate tokens
// or destinations. This project's other app (ggapp) uses Realtime Database,
// not Firestore, so a blanket deny here is safe.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
