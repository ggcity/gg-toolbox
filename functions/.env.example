# Password for the QR recovery directory at /qradmin?key=…
# Copy this file to functions/.env and set a strong random value:
#   node -e "console.log(require('crypto').randomBytes(18).toString('base64url'))"
# The real .env is git-ignored; this .example is just documentation.
QR_ADMIN_KEY=change-me

# Neutral public origin for resident-facing QR short-links (/q/) and stats (/s/).
# Empty falls back to the request host. e.g. https://ggc-go.web.app
QR_PUBLIC_BASE=
